# ═══════════════════════════════════════════════════════════════════════════
# Automation Service v2.0 - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────
# Service Configuration
# ──────────────────────────────────────────────────────────────────────────
SERVICE_NAME=automation-service
SERVICE_PORT=8009
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────
# Worker Configuration
# ──────────────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=4
WORKER_CONCURRENCY=16
BATCH_SIZE=50
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# ──────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ──────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Production: rediss://your-redis.upstash.io:6379

# Event Streams
EVENT_STREAM_NAME=automation_events
DLQ_STREAM_NAME=automation_dlq
CONSUMER_GROUP_NAME=automation_group

# ──────────────────────────────────────────────────────────────────────────
# PostgreSQL Configuration
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/mailautomation
# Production: postgresql+asyncpg://user:pass@postgres.rds.amazonaws.com:5432/mailautomation

# ──────────────────────────────────────────────────────────────────────────
# Qdrant Vector Database
# ──────────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=business_context
QDRANT_VECTOR_SIZE=768
# Production: https://your-cluster.qdrant.cloud:6333

# ──────────────────────────────────────────────────────────────────────────
# OpenAI Configuration
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2

# ──────────────────────────────────────────────────────────────────────────
# Embedding Configuration
# ──────────────────────────────────────────────────────────────────────────
EMBED_DEVICE=auto
# Options: auto (detect GPU), cuda (force GPU), cpu (force CPU)

EMBED_SERVICE_URL=http://localhost:8009
# URL for CPU workers to delegate embedding to GPU worker

HF_TOKEN=
# HuggingFace token for downloading models (optional but recommended)

# ──────────────────────────────────────────────────────────────────────────
# Retrieval Configuration
# ──────────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=8
RETRIEVAL_SCORE_THRESHOLD=0.30
RERANKER_TOP_N=5

USE_BGE_RERANKER=false
# Set to true only if GPU available (enables cross-encoder reranking)

BGE_DEVICE=auto
# Options: auto, cuda, cpu

# ──────────────────────────────────────────────────────────────────────────
# Performance Tuning
# ──────────────────────────────────────────────────────────────────────────
MAX_SLOW_PATH_CONCURRENT=32
EMBED_BATCH_MAX_SIZE=32
EMBED_BATCH_TIMEOUT_MS=50

# Token Budget
MAX_CONTEXT_CHARS=2000
MAX_HISTORY_MESSAGES=6
MAX_CHUNK_CHARS=400

# ──────────────────────────────────────────────────────────────────────────
# Confidence Thresholds
# ──────────────────────────────────────────────────────────────────────────
CONFIDENCE_SEND_THRESHOLD=0.55
CONFIDENCE_SKIP_THRESHOLD=0.25

# ──────────────────────────────────────────────────────────────────────────
# Cache TTLs (seconds)
# ──────────────────────────────────────────────────────────────────────────
RESPONSE_CACHE_TTL=300
INTENT_CACHE_TTL=600
EMBED_CACHE_TTL=86400
CONV_CACHE_TTL=86400

# ──────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_USER_PER_MIN=30
RATE_LIMIT_WINDOW_S=60

# ──────────────────────────────────────────────────────────────────────────
# Observability
# ──────────────────────────────────────────────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090

ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ──────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ──────────────────────────────────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────────────────────────────────
USE_MULTI_EMBED=false
# Legacy multi-embed strategy (default: false, use single optimized embed)

USE_RERANKER=false
# Legacy reranker (default: false, use hybrid BM25+vector scoring)

RIE_ENABLED=true
# Relevance Intelligence Engine filter
