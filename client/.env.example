# API Gateway URL - Single entry point for ALL API calls
# All requests (auth, user, business, email, etc.) route through this gateway
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (used for canonical URLs, OG tags, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://proxipilot.com

# Production Configuration
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# Development Notes:
# - Gateway service must be running on port 8000
# - Gateway routes to all microservices (auth, user, business, etc.)
# - Never call microservices directly (ports 8001-8011)
# - All authentication is handled via JWT tokens in localStorage
